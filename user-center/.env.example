# Copy this file to `.env` (same directory as the running JAR) and adjust the values.
# In the Docker image built from the bundled Dockerfile, place it at /app/.env.
# The file is loaded by run.sh via `set -a` + `source`, so shell quoting/escaping rules apply.
# Lines starting with `#` are comments. Do NOT wrap values in quotes unless the value itself needs them.

# ---- Datasource (maps to spring.datasource.* in application.yml) ----
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=euler_uc
DATABASE_USERNAME=root

# Password for the database user.
# - Set a value for password-protected accounts, e.g. DATABASE_PASSWORD=secret
# - For a password-less account (e.g. local dev with MySQL `root@localhost` using auth_socket,
#   or a user created with an empty password), leave the value blank or comment the line out:
#       DATABASE_PASSWORD=
#   or
#       # DATABASE_PASSWORD=
#   In both cases application.yml falls back to an empty string, which the MySQL JDBC driver
#   treats as "no password".
DATABASE_PASSWORD=

# ---- Redis (maps to spring.data.redis.* in application.yml) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# Password for Redis (the `requirepass` directive or ACL user password).
# - Set a value when Redis has authentication enabled, e.g. REDIS_PASSWORD=secret
# - For an unauthenticated Redis (default standalone setup without `requirepass`), leave the
#   value blank or comment the line out:
#       REDIS_PASSWORD=
#   or
#       # REDIS_PASSWORD=
#   In both cases application.yml falls back to an empty string, and Spring Data Redis will
#   skip the AUTH command.
REDIS_PASSWORD=
